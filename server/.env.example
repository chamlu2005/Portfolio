# Server configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here

# Database configuration (Leave empty to use automatic SQLite fallback)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=portfolio_cms
DB_PORT=3306

# SMTP Email Alert Service (Optional - Nodemailer configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFICATION_EMAIL=alerts@yourdomain.com

# AI Provider Credentials (Optional - Falls back to offline rules if empty)
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
OLLAMA_HOST=http://localhost:11434
